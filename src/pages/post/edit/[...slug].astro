---
import Layout from "@layouts/Layout.astro";
import PostEditing from "@components/PostEditing.svelte";
import { getPost } from "@utils/prisma";
const { slug } = Astro.params;
const { user } = Astro.locals;

if (isNaN(Number(slug)) || !user.canPost)
  return new Response(null, { status: 403 });

const post = await getPost(Number(slug));
if (!post || post.authorId !== user.id)
  return new Response(null, { status: 404 });
---

<Layout title={`BB Blog - ${post?.title}`}>
  <form style="width: 760px; text-align: left;" method="POST" action="/api/post/edit">
    <a href={`/post/${post.id}`}>&lt;-- Back To Post</a>
    <br>
    <input type="hidden" name="id" value={post.id} />
    <label for="title">Title</label>
    <input type="text" name="title" value={post.title} id="title" />
    <br>
    <PostEditing content={post.content} client:load />
    <button type="submit">Submit</button>
  </form>
</Layout>
