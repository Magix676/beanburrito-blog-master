    }

    a:hover {
      text-decoration: underline;
    }
  </style>

<table cellpadding="0" cellspacing="0" border="0" width="760">
  <tbody
    ><tr>
      <td valign="top" style="width: 33px;">
        {user? <a href="/api/auth/logout">Logout</a> : <a href="/api/auth/login">Login</a>}
      </td>
      <td valign="top" align="center" style="width: 64px;">
        <a href="http://beanburrito.tech/">
            <img
            src="/buttons/BB.png"
            width="36"
            height="36"/>
            <br />
            <nobr><font face="verdana" size="-2" color="#000000">Home</font></nobr>
        </a>
      </td>
      <td valign="top" align="center" style="width: 64px;">
        <a href="http://archive.beanburrito.tech/">
            <img
            src="/buttons/home.png"
            width="36"
            height="36"/>
            <br />
            <nobr><font face="verdana" size="-2" color="#000000">Archive</font></nobr>
